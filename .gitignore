*.db
*.db-shm
*.db-wal

# ─── Node / Next.js ─────────────────────────────────────────────────────────
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS / Editor ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ─── Docker build artifacts ──────────────────────────────────────────────────
.dockerignore
