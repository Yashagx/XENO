# ─── Credentials & secrets — NEVER commit these ────────────────────────────
.env
.env.production
.env.local
.env.*.local
*.pem
*.key

# ─── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

