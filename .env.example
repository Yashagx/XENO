# Environment — XENO ORACLE
# Copy this to .env and fill in your values

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://xeno:xenopassword@localhost:5432/xeno_oracle
DATABASE_URL_SYNC=postgresql://xeno:xenopassword@localhost:5432/xeno_oracle

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── AI / LLM ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Get free key at: https://aistudio.google.com
GEMINI_MODEL=gemini-2.0-flash

# ─── Embeddings ─────────────────────────────────────────────
EMBEDDING_MODEL=models/text-embedding-004
EMBEDDING_DIMENSION=768

# ─── Auth ───────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ─── Channel Service ────────────────────────────────────────
CHANNEL_SERVICE_URL=http://localhost:8001
CRM_CALLBACK_URL=http://localhost:8000/api/v1/campaigns/callbacks

# ─── Backend ────────────────────────────────────────────────
BACKEND_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
